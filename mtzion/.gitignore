# Log output / artifacts only — do not use a bare "logs" rule: it matches src/pages/Admin/Logs
# on case-insensitive filesystems and would prevent those UI files from being committed.
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.env
